# ==============================================================================
# GLOBAL SETTINGS
# ==============================================================================
NODE_ENV=development

# ==============================================================================
# JWT
# ==============================================================================
JWT_SECRET=your_super_secret_jwt_key_minimum_32_characters_long
JWT_REFRESH_SECRET=your_super_secret_refresh_key_minimum_32_characters_long
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ==============================================================================
# POSTGRESQL (Auth, User, Order Services)
# ==============================================================================
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=ecommerce
POSTGRES_PASSWORD=ecommerce_password
POSTGRES_DB=ecommerce
DATABASE_URL=postgresql://ecommerce:ecommerce_password@postgres:5432/ecommerce

# ==============================================================================
# MONGODB (Product Service)
# ==============================================================================
MONGO_URI=mongodb://mongo:27017/ecommerce-products

# ==============================================================================
# REDIS (Sessions, Events, Cache)
# ==============================================================================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379

# ==============================================================================
# STRIPE (Payment Service)
# ==============================================================================
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret_here

# ==============================================================================
# RESEND (Notification Service - Email)
# ==============================================================================
RESEND_API_KEY=re_your_resend_api_key_here
EMAIL_FROM=noreply@yourdomain.com
EMAIL_FROM_NAME=Your Store

# ==============================================================================
# SERVICE PORTS
# ==============================================================================
API_GATEWAY_PORT=3000
AUTH_SERVICE_PORT=4001
USER_SERVICE_PORT=4002
PRODUCT_SERVICE_PORT=4003
ORDER_SERVICE_PORT=4004
PAYMENT_SERVICE_PORT=4005
NOTIFICATION_SERVICE_PORT=4006

# ==============================================================================
# SERVICE URLS (used by API Gateway)
# ==============================================================================
AUTH_SERVICE_URL=http://auth-service:4001
USER_SERVICE_URL=http://user-service:4002
PRODUCT_SERVICE_URL=http://product-service:4003
ORDER_SERVICE_URL=http://order-service:4004
PAYMENT_SERVICE_URL=http://payment-service:4005

# ==============================================================================
# FRONTEND
# ==============================================================================
NEXT_PUBLIC_API_URL=http://localhost:3000
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key_here

# ==============================================================================
# BCRYPT
# ==============================================================================
BCRYPT_ROUNDS=12
